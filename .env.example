# Hugging Face token — needed at build time only
# Get yours at https://huggingface.co/settings/tokens
# Must have accepted the embeddinggemma license at
# https://huggingface.co/google/embeddinggemma-300m
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx

# API key that callers must pass in the X-API-Key header
# Generate something random: python -c "import secrets; print(secrets.token_urlsafe(32))"
CHECKER_API_KEY=your-secret-key-here

# OpenAI key for LLM adjudication (gpt-4o-mini)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx